{
  "name": "@acme/prisma",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./factories": {
      "types": "./dist/factories/index.d.ts",
      "import": "./dist/factories/index.mjs",
      "require": "./dist/factories/index.js"
    }
  },
  "module": "./dist/index.mjs",
  "main": "./dist/index.js",
  "scripts": {
    "build": "prisma generate && acme-scripts build && acme-scripts build src/factories/index.ts --project tsconfig.build-factories.json --outDir dist/factories",
    "dev": "prisma generate --watch",
    "lint": "acme-scripts lint"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/scripts": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "prisma": "3.15.1",
    "prisma-factory": "0.1.12",
    "typescript": "4.7.3"
  },
  "dependencies": {
    "@faker-js/faker": "7.2.0",
    "@prisma/client": "3.15.1"
  }
}
